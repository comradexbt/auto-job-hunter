[Unit]
Description=Auto Job Hunter Bot - 24/7 Job Application Service
After=network.target

[Service]
Type=simple
User=your_username
WorkingDirectory="/path/to/AUTO JOBS TOOL/job_bot"
Environment="PATH=/usr/local/bin:/usr/bin:/bin"
EnvironmentFile="/path/to/AUTO JOBS TOOL/job_bot/.env"
ExecStart=/usr/bin/python3 "/path/to/AUTO JOBS TOOL/job_bot/main.py"
Restart=always
RestartSec=3600
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
